# =============================================================================
# Tender Getter RSA — Environment Variables Template
# Version: 1.1.0
#
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# .env is git-ignored. NEVER commit real credentials to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE DRIVER SELECTION
#
# When SUPABASE_DB_URL is set, get_database_client() returns PostgresDatabase.
# When unset (or empty), it returns the local SQLite TenderDatabase.
#
# Format:
#   postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
#
# Supabase example (find in: Project Settings → Database → Connection string):
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Leave blank for local development / unit testing (SQLite is used automatically).
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# GOOGLE AI STUDIO — Gemini API Key
# Used by src/tender_getter/parser.py for OCR and compliance extraction.
# Obtain from: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Override local SQLite database path (development only)
# Default: localdata/tender_getter.db (relative to project root)
# -----------------------------------------------------------------------------
# LOCAL_DB_PATH=./localdata/tender_getter.db
