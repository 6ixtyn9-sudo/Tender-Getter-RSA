# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Google AI — Gemini
# Single key:
GEMINI_API_KEY=
#
# Multiple keys for rate-limit load-balancing (free-tier rotation).
# Either format works (both can be combined):
#   GEMINI_API_KEY=key1,key2,key3
#   GEMINI_API_KEY_1=key1
#   GEMINI_API_KEY_2=key2
#   GEMINI_API_KEY_3=key3
# The system rotates across all keys and auto-parks any that hit a 429.
#
# Model override (defaults to gemini-flash-latest):
# GEMINI_MODEL_VISION=gemini-2.5-pro

ENV=development



# Twilio / WhatsApp (required in production; unsigned webhooks are rejected)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TG_CORS_ORIGINS=
TG_WEBHOOK_RATE_PER_MINUTE=30
TG_MAX_MEDIA_BYTES=15728640
# Only set to 1 for unsigned local webhook testing. Never set in production.
TG_ALLOW_INSECURE_WEBHOOK=0

# Billing (all customer plans are paid; beta is an explicit temporary entitlement)
BILLING_PROVIDER=paystack
PAYSTACK_SECRET_KEY=
# Debit order / DebiCheck provider onboarding is configured after merchant approval.
STITCH_CLIENT_ID=
STITCH_CLIENT_SECRET=
# Recurring Paystack product/plan IDs created in the Paystack merchant account.
# Checkout remains disabled until all selected plan IDs and callback URL are set.
PAYSTACK_PLAN_STARTER_MONTHLY=
PAYSTACK_PLAN_STARTER_ANNUAL=
PAYSTACK_PLAN_PRO_MONTHLY=
PAYSTACK_PLAN_PRO_ANNUAL=
PAYSTACK_PLAN_VIP_MONTHLY=
PAYSTACK_PLAN_VIP_ANNUAL=
BILLING_CALLBACK_URL=
# Security resilience: distributed inbound guard uses Supabase RPC in production.
# Do not grant anon access to billing, WhatsApp, agent or feedback tables.
